{
  "ConnectionStrings": {
    "SqlServer": "Server=YOUR_SERVER;Database=master;Integrated Security=true;TrustServerCertificate=true;"
  },
  "SqlMetro": {
    "PollIntervalSeconds": 3,
    "MaxTrainsPerDatabase": 20,
    "WaitStatTopN": 15,
    "SlowQueryThresholdMs": 500,
    "ExcludeSessions": [ "sa", "NT AUTHORITY\\SYSTEM", "NT SERVICE\\SQLTELEMETRY" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
